# ═════════════════════════════════════════════════════════════════════════════
# Spectra — variables d'environnement optionnelles
#
# ┌─ L'ESSENTIEL ──────────────────────────────────────────────────────────────┐
# │ Dans la plupart des cas, vous n'avez RIEN à configurer ici :               │
# │                                                                            │
# │   ./start.sh --first-run     (Windows : start.bat --first-run)             │
# │                                                                            │
# │ télécharge les modèles par défaut, démarre la stack et ouvre               │
# │ http://localhost — sans toucher à ce fichier.                              │
# │                                                                            │
# │ Les DEUX seules variables à connaître (pour changer de modèle) :           │
# │   LLM_CHAT_MODEL_FILE   nom du .gguf de chat dans data/models/             │
# │   LLM_EMBED_MODEL_FILE  nom du .gguf d'embedding dans data/models/         │
# │                                                                            │
# │ Tout le reste de ce fichier est du réglage avancé, avec des défauts        │
# │ fonctionnels fournis par docker-compose.yml.                               │
# └────────────────────────────────────────────────────────────────────────────┘
#
# Copiez ce fichier en ".env" à la racine du projet pour surcharger les
# valeurs par défaut de docker-compose.yml :
#
#   cp .env.example .env
#
# NB : ./detect-env.sh (lancé par start.sh) crée/complète aussi .env
# automatiquement selon le matériel détecté (CPU/RAM/GPU).
# ═════════════════════════════════════════════════════════════════════════════

# ── Modèles GGUF (l'essentiel) ───────────────────────────────────────────────
# NB : ces noms de variables sont ceux réellement lus par docker-compose.yml.

# Nom du fichier GGUF de chat dans data/models/ (monté dans les conteneurs LLM).
# Placé manuellement ou téléchargé via ./setup.sh --download-chat.
# Défaut : Phi-4-mini-reasoning-UD-IQ1_S.gguf
LLM_CHAT_MODEL_FILE=Phi-4-mini-reasoning-UD-IQ1_S.gguf

# Nom logique (alias) du modèle de chat dans le registre Spectra. Purement
# cosmétique : le fichier ci-dessus est la source réelle, transmise au registre
# via SPECTRA_LLM_CHAT_FILE (câblé automatiquement par docker-compose.yml).
# Défaut : phi-4-mini
LLM_CHAT_MODEL_NAME=phi-4-mini

# Nom du fichier GGUF d'embedding dans data/models/
# Télécharger nomic-embed-text (~81 Mo) :
#   curl -L https://huggingface.co/nomic-ai/nomic-embed-text-v1.5-GGUF/resolve/main/nomic-embed-text-v1.5.Q4_K_M.gguf \
#        -o data/models/embed.gguf
# Défaut : embed.gguf
LLM_EMBED_MODEL_FILE=embed.gguf

# Nom logique du modèle d'embedding. Défaut : nomic-embed-text
LLM_EMBED_MODEL_NAME=nomic-embed-text

# ═════════════════════════════════════════════════════════════════════════════
# RÉGLAGES AVANCÉS — tout ce qui suit est optionnel et a un défaut fonctionnel.
# ═════════════════════════════════════════════════════════════════════════════

# ── Model Hub (llmfit) ────────────────────────────────────────────────────────

# Cache de téléchargement propre à l'outil llmfit. Inventorié par le rapport de
# stockage du Model Hub et purgeable de ses doublons (fichiers dont nom ET taille
# correspondent à un GGUF déjà dans data/models/). À ajuster si votre build de
# llmfit cache ailleurs. Défaut : ~/.llmfit
#LLMFIT_CACHE_DIR=

# Rétention de l'historique des installations : les jobs terminés
# (COMPLETED/FAILED/CANCELLED) plus vieux que N jours sont purgés chaque nuit.
# Défaut : 0 = conserver indéfiniment.
#LLMFIT_INSTALL_RETENTION_DAYS=90

# ── Image llama.cpp des serveurs LLM (llm-chat / llm-embed) ───────────────────

# Tag de l'image ghcr.io/ggml-org/llama.cpp. Le défaut est ÉPINGLÉ sur un build
# versionné : le tag mobile « server » est reconstruit en continu depuis master
# (plusieurs fois par jour) et un build cassé fait mourir les serveurs LLM au
# démarrage. Mettre « server » pour suivre master, ou un autre server-bXXXX.
# Défaut : server-b9828
#LLAMA_CPP_IMAGE_TAG=server-b9828

# ── Contexte et parallélisme du serveur de chat ───────────────────────────────

# Taille de contexte totale du serveur de chat (en tokens).
# Chaque slot parallèle reçoit : LLM_CONTEXT / LLM_PARALLEL tokens.
#
# ATTENTION : le modèle fine-tuné a un plafond d'entraînement de 2048 tokens
# (n_ctx_train). Augmenter LLM_CONTEXT au-delà de 2048 n'élargit pas
# la fenêtre effective si le modèle n'a pas été entraîné avec plus.
# Laisser VIDE (ou commenter) = dimensionnement automatique : llm-chat applique
# les recommandations calculées par l'API (data/models/active-chat-params) selon
# le CPU/RAM détectés. Définir une valeur l'impose (priorité utilisateur).
LLM_CONTEXT=2048

# Nombre de slots parallèles (conversations simultanées).
# Chaque slot consomme : LLM_CONTEXT / LLM_PARALLEL tokens.
# Avec LLM_PARALLEL=1 : tout le contexte est dédié à une requête à la fois.
# Augmenter LLM_CONTEXT proportionnellement si vous augmentez LLM_PARALLEL.
# Défaut : 1
LLM_PARALLEL=1

# Période (secondes) de surveillance du modèle actif par llm-chat.
# L'entrypoint superviseur lit le pointeur data/models/active-chat-model (écrit
# par l'API à chaque activation) et recharge llama-server quand il change —
# aucun redémarrage manuel du conteneur n'est nécessaire.
# Défaut : 10
LLM_CHAT_WATCH_INTERVAL=10

# ── Évaluation LLM-as-a-judge ──────────────────────────────────────────────────

# Modèle-juge neutre pour l'évaluation. Vide = le modèle évalué se juge lui-même
# (biais possible). Renseigner un modèle distinct et fixe rend la comparaison
# multi-modèles plus équitable. L'évaluation se fait alors en 2 phases :
# génération des réponses avec le modèle évalué, puis notation avec le juge.
# Défaut : vide (auto-jugement)
SPECTRA_EVALUATION_JUDGE_MODEL=

# Nombre maximal de rapports d'évaluation COMPLETED conservés (les plus anciens
# sont évincés). Ils sont nécessaires aux comparaisons multi-modèles.
# Défaut : 200
SPECTRA_EVALUATION_MAX_COMPLETED_REPORTS=200

# ── Ingestion streaming Kafka (données vivantes → RAG au fil de l'eau) ─────────
# Désactivé par défaut. Quand activé, Spectra consomme des topics Kafka et
# « upserte » chaque message dans l'index RAG : la clé du message sert d'identité
# métier stable (sourceFile = kafka://<topic>/<key>) permettant de remplacer la
# version précédente ; un message à valeur nulle (tombstone) supprime l'entrée.
# Défaut : false
SPECTRA_KAFKA_ENABLED=false

# Brokers Kafka (host:port séparés par des virgules). Défaut : localhost:9092
# depuis l'hôte. Le broker du profil `kafka` (identique à celui du docker-compose
# de Kafka Explorer, apache/kafka:4.2.0) publie ce listener sur localhost:9092.
# ATTENTION : quand spectra-api tourne DANS le compose, il joint le broker via le
# listener interne `kafka:29092` (valeur par défaut injectée par docker-compose).
# Ne définissez cette variable que pour pointer un broker EXTERNE.
SPECTRA_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Topics à consommer (séparés par des virgules). Vide = aucun. Défaut : vide
SPECTRA_KAFKA_TOPICS=

# Consumer group. Défaut : spectra-ingestion
SPECTRA_KAFKA_GROUP_ID=spectra-ingestion

# Collection ChromaDB dédiée au flux (isole les données vivantes du corpus
# documentaire statique). Défaut : spectra_stream
SPECTRA_KAFKA_COLLECTION=spectra_stream

# Format de routage de l'extracteur (payload brut) : json|txt|xml|avro. Défaut : json
SPECTRA_KAFKA_FORMAT=json

# (JSON) Champ dont la valeur est indexée à la place du payload brut. Nom simple
# ("body") ou pointeur JSON ("/data/text"). Vide = payload brut. Défaut : vide
SPECTRA_KAFKA_CONTENT_FIELD=
# (JSON) Champs recopiés dans les métadonnées (séparés par des virgules), pour le
# filtrage/tri au retrieval. Ignoré si CONTENT_FIELD vide. Défaut : vide
SPECTRA_KAFKA_METADATA_FIELDS=

# Consumers concurrents (≈ partitions traitées en parallèle). Défaut : 1
SPECTRA_KAFKA_CONCURRENCY=1

# Messages max par poll (bas : chaque message déclenche un embedding). Défaut : 20
SPECTRA_KAFKA_MAX_POLL_RECORDS=20

# Purge des sources non mises à jour depuis N jours (0 = désactivé). Défaut : 0
SPECTRA_KAFKA_RETENTION_TTL_DAYS=0
# Planification (cron Spring) de la purge de rétention. Défaut : 03h30
SPECTRA_KAFKA_RETENTION_CRON=0 30 3 * * *

# Sécurité : PLAINTEXT | SSL | SASL_SSL | SASL_PLAINTEXT. Défaut : PLAINTEXT
SPECTRA_KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# Mécanisme SASL (ex. SCRAM-SHA-512, PLAIN) si SASL. Défaut : vide
SPECTRA_KAFKA_SASL_MECHANISM=
# Config JAAS complète (contient les identifiants) si SASL. Défaut : vide
SPECTRA_KAFKA_SASL_JAAS_CONFIG=
