# ─────────────────────────────────────────────────────────────────────────────
# Spectra — variables d'environnement optionnelles
#
# Copiez ce fichier en ".env" à la racine du projet pour surcharger les
# valeurs par défaut de docker-compose.yml.
#
#   cp .env.example .env
#
# Aucune valeur n'est obligatoire : docker-compose.yml contient des défauts
# fonctionnels pour chaque variable.
# ─────────────────────────────────────────────────────────────────────────────

# ── Modèles GGUF ─────────────────────────────────────────────────────────────

# Nom du fichier GGUF de chat dans data/fine-tuning/merged/
# Ce fichier est produit automatiquement par le fine-tuning ou placé manuellement.
# Défaut : model.gguf
LLAMA_CHAT_MODEL=model.gguf

# Nom du fichier GGUF d'embedding dans data/models/
# Télécharger nomic-embed-text (~81 Mo) :
#   curl -L https://huggingface.co/nomic-ai/nomic-embed-text-v1.5-GGUF/resolve/main/nomic-embed-text-v1.5.Q4_K_M.gguf \
#        -o data/models/embed.gguf
# Défaut : embed.gguf
LLAMA_EMBED_MODEL=embed.gguf

# ── Contexte et parallélisme du serveur de chat ───────────────────────────────

# Taille de contexte totale du serveur de chat (en tokens).
# Chaque slot parallèle reçoit : CONTEXT_SIZE / PARALLELISM tokens.
#
# ATTENTION : le modèle fine-tuné a un plafond d'entraînement de 2048 tokens
# (n_ctx_train). Augmenter CONTEXT_SIZE au-delà de 2048 n'élargit pas
# la fenêtre effective si le modèle n'a pas été entraîné avec plus.
# Défaut : 8192
LLAMA_CHAT_CONTEXT_SIZE=8192

# Nombre de slots parallèles (conversations simultanées).
# Chaque slot consomme : CONTEXT_SIZE / PARALLELISM tokens.
# Avec PARALLELISM=1 : tout le contexte est dédié à une requête à la fois.
# Avec PARALLELISM=4 et CONTEXT_SIZE=8192 : 2048 tokens par slot.
# Augmenter CONTEXT_SIZE proportionnellement si vous augmentez PARALLELISM.
# Défaut : 1
LLAMA_CHAT_PARALLELISM=1
