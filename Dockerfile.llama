# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.llama — image llama.cpp avec entrypoint intelligent (autostart)
#
# Construit l'image `spectra-llama-cpp` utilisée par les déploiements
# k8s/05-llama-embed.yaml et k8s/06-llama-chat.yaml.
#
# Elle embarque le script scripts/llama-autostart.sh, qui détecte les
# ressources (CPU/RAM/GPU) et calcule les paramètres optimaux de llama-server.
#
#   docker build -f Dockerfile.llama -t spectra-llama-cpp:latest .
# ─────────────────────────────────────────────────────────────────────────────
FROM ghcr.io/ggml-org/llama.cpp:server

# Le binaire `llama-server` de l'image amont vit dans /app ; on l'ajoute au PATH
# pour que llama-autostart.sh puisse l'invoquer par son nom.
ENV PATH="/app:${PATH}"

# Scripts intégrés à l'image (les manifests choisissent lequel via `command`) :
#  - llama-autostart.sh      : entrypoint autonome (défaut, utilisé pour l'embedding)
#  - llm-chat-entrypoint.sh  : superviseur piloté par le registre pour le chat — suit le
#    modèle ACTIF (pointeur /models/active-chat-model) et redémarre llama-server à chaud,
#    résolvant « modèle actif ≠ modèle servi » aussi en k8s (comme en docker-compose).
COPY scripts/llama-autostart.sh /scripts/llama-autostart.sh
COPY scripts/llm-chat-entrypoint.sh /scripts/llm-chat-entrypoint.sh
RUN chmod +x /scripts/llama-autostart.sh /scripts/llm-chat-entrypoint.sh

ENTRYPOINT ["/bin/bash", "/scripts/llama-autostart.sh"]
